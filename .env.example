# ─────────────────────────────────────────────────────────────────────────────
# FarmaCompara Node Agent — Variables de entorno
# cp .env.example .env  y luego editar los valores
# ─────────────────────────────────────────────────────────────────────────────

# ── Seguridad — deben coincidir EXACTAMENTE con los valores del manager ───────
NODE_AGENT_API_KEY=CHANGE_ME_node_agent_api_key
HMAC_SECRET=CHANGE_ME_min32_hmac_secret

# ── Conexión con el manager ───────────────────────────────────────────────────
# IP o dominio del manager, accesible desde este nodo (normalmente vía VPN)
MANAGER_URL=http://10.0.0.1:8000

# Intervalo de push de métricas al manager (segundos)
PUSH_INTERVAL=15

# ── Identidad del nodo — se llenan DESPUÉS de registrar con: make register ────
# Dejar vacíos la primera vez. El agente arranca en modo pre-registro.
NODE_ID=
NODE_JWT=

# ── Límite de tamaño de respuesta capturada (chars). Por defecto: 512 KB ──────
NODE_MAX_BODY_SIZE=512000
